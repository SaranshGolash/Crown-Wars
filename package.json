{
  "name": "chess-game-with-buffs",
  "version": "1.0.0",
  "description": "A monorepo for Chess Game with buffs",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently \"npm run start --workspace=client\" \"npm run start --workspace=server\"",
    "build": "npm run build --workspace=client",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
